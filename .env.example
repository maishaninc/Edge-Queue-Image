# ============================================================
#  仅这 2 个环境变量是必需的（其余配置都在后台「系统设置」里完成）
# ============================================================

# Aiven PostgreSQL 连接串。
# 建议使用 Aiven 控制台的「Connection pooling（PgBouncer）」URI 以适配 Vercel Serverless。
# 形如：postgres://avnadmin:password@host-xxxx.aivencloud.com:PORT/defaultdb?sslmode=require
DATABASE_URL=

# Aiven 提供的 CA 证书（ca.pem 的完整内容，含 -----BEGIN/END CERTIFICATE----- 行）。
# 在 Vercel 环境变量里可直接粘贴多行 PEM 文本。
DATABASE_CA_CERT=

# ------------------------------------------------------------
# 可选：本地开发时若用「sslmode=disable」的本地 Postgres，可不填 DATABASE_CA_CERT。
# 首次启动会自动建表并创建默认管理员：用户名 admin / 密码 admin（首次登录强制改密）。
# OAuth(Google/GitHub) 客户端密钥、模型 API Key、谷歌广告、验证码均在后台填写。
# ------------------------------------------------------------
