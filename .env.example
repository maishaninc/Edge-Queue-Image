MODEL=gpt-image-1
KEY=sk-your-default-key
API=https://api.openai.com

# Optional additional OpenAI-compatible image providers.
# MODEL_1=
# KEY_1=
# API_1=

QUEUE_CONCURRENCY=50
QUEUE_MAX_WAITING=200
QUEUE_POLL_INTERVAL_MS=3000
RUNNING_JOB_TIMEOUT_SECONDS=300
JOB_RESULT_TTL_MINUTES=15

PRIORITY_QUEUE_ENABLED=true
PRIORITY_DAILY_LIMIT=1

# none | turnstile | hcaptcha
CAPTCHA_PROVIDER=none
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
HCAPTCHA_SITE_KEY=
HCAPTCHA_SECRET_KEY=

# Local development uses a file database and does not need TURSO_AUTH_TOKEN.
TURSO_DATABASE_URL=file:local-dev.db
# TURSO_AUTH_TOKEN is required only for remote Turso, for example on Vercel.
# TURSO_AUTH_TOKEN=
IP_HASH_SALT=change-this-in-production
