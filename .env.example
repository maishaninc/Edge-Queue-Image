# ============================================================
#  必需的 4 个环境变量
# ============================================================

# 1) Aiven PostgreSQL 连接串（建议用控制台「连接池 / PgBouncer」URI 以适配 Serverless）
DATABASE_URL=postgres://avnadmin:password@host-xxxx.aivencloud.com:PORT/defaultdb?sslmode=require

# 2) Aiven 提供的 CA 证书（ca.pem 完整内容，含 BEGIN/END CERTIFICATE 行；Vercel 可直接粘贴多行）
DATABASE_CA_CERT=

# 3) 管理员账号
ADMIN_USERNAME=admin

# 4) 管理员密码（部署后用它登录后台；每次部署会以此为准同步管理员密码）
ADMIN_PASSWORD=

# ------------------------------------------------------------
# 其余配置（OAuth 密钥、模型 API Key、广告、验证码、签到额度）都在后台「系统设置」里填写并存数据库。
# 本地无 SSL 的 Postgres 可不填 DATABASE_CA_CERT。
# ------------------------------------------------------------
